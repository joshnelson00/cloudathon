ENVIRONMENT=local
PORT=8000
ALLOWED_ORIGINS=*
SERVICE_ENDPOINTS_JSON={"analytics":"","notifications":"","payments":""}

# Database configuration
# use_mock_db=true: Use JSON file-based mock database (default for demo)
# use_mock_db=false: Use real AWS DynamoDB (requires AWS credentials and deployed tables)
USE_MOCK_DB=true

# S3 bucket for compliance PDFs (leave empty to save locally to /tmp)
S3_COMPLIANCE_BUCKET=hackathon-dev-compliance-docs-412381748467

# Lambda function name for compliance PDF generation (leave empty for local generation)
LAMBDA_COMPLIANCE_FUNCTION_NAME=

# Analytics mode
# backend: use DynamoDB scan + filtering (default)
# athena: use Athena query templates (requires Athena resources and table)
ANALYTICS_MODE=backend
ATHENA_ENABLED=false
ATHENA_DATABASE=
ATHENA_TABLE=
ATHENA_WORKGROUP=
ATHENA_OUTPUT_S3=
